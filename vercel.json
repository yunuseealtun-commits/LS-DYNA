{
  "version": 2,
  "builds": [
    {
      "src": "api/data.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/register",
      "destination": "/api/data?route=register"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/data?route=login"
    },
    {
      "source": "/api/drive/login",
      "destination": "/api/data?route=drive_login"
    },
    {
      "source": "/api/drive/sync",
      "destination": "/api/data?route=drive_sync"
    },
    {
      "source": "/api/drive/callback",
      "destination": "/api/data?route=drive_callback"
    },
    {
      "source": "/api/data",
      "destination": "/api/data"
    },
    {
      "source": "/(.*)",
      "destination": "/App/$1"
    },
    {
      "source": "/",
      "destination": "/App/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}